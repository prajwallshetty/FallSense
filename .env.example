EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=safefall-ai.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=safefall-ai
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=safefall-ai.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=849204020102
EXPO_PUBLIC_FIREBASE_APP_ID=1:849204020102:web:7a6b5c4d3e2f1g

# Emergency Gateway API Configuration (Optional)
